# Backend
PORT=8080
FRONTEND_URL=http://localhost:3000

# Base de datos (PostgreSQL)
# Local (Docker): docker compose -f compose.yaml up -d postgres
# Compartida (mismos datos para todos): ver docs/base-datos-compartida-nube.md
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mytsyy
# Ejemplo si usas BD en la nube (Supabase/Neon): POSTGRES_HOST=db.xxxxx.supabase.co

# Redis (sesiones del agente conversacional)
# Local con Docker: docker compose up -d redis  →  redis://localhost:6379
# Si no se define, las sesiones se guardan en memoria (se pierden al reiniciar).
REDIS_URL=redis://localhost:6379

# Opcional: TTL de la sesión en Redis (segundos). Por defecto 7 días.
# SESSION_TTL_SECONDS=604800

# IA (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# JWT (auth)
JWT_SECRET=tu-secreto-muy-largo-y-seguro
